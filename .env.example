# Copy this file to .env and fill in the values

# Claude AI (required)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (required)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT secret — use any long random string
JWT_SECRET=change-this-to-a-long-random-secret-string

# Database (Railway provides this automatically when you add PostgreSQL)
# For local dev you can use SQLite — leave blank or set to sqlite:///./hse.db
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend Google Client ID (used during Docker build)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
